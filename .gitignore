# Source files (PDFs, epubs) are kept locally but not committed.
# `sources` is a symlink to ~/Desktop/Sources/books/. Both pattern forms
# are listed so the symlink itself never gets tracked — git treats a
# symlink-to-a-directory as a special file, so `sources/` (with slash)
# alone wouldn't match it.
sources
sources/

